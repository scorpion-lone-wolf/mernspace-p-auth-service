{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "The user management service",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "src/server.ts",
  "scripts": {
    "test:watch": "vitest",
    "test:once": "vitest run --reporter=verbose",
    "dev": "cross-env NODE_ENV=development nodemon src/server.ts",
    "format:fix": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "build": "tsc",
    "prepare": "husky",
    "start": "ts-node src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run format:fix",
      "npm run lint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^26.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.5",
    "typeorm": "1.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
