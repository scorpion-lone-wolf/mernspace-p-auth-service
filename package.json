{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "The user management service",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/app.js\"",
    "format:fix": "npx prettier . --write",
    "format:check": "npx prettier . --check",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "build": "tsc",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run format:fix",
      "npm run lint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
